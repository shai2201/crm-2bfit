# Copy this file to .env.local and fill in your values

# PostgreSQL connection (Supabase / Railway / local)
DATABASE_URL="postgresql://user:password@localhost:5432/2bfit_db"

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI (for Nutrition AI module)
OPENAI_API_KEY="sk-..."

# Stripe (for payments & subscriptions)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Demo user IDs (replace with real auth session in production)
DEMO_TRAINEE_ID="clxxxxxxxxxxxxxx"
